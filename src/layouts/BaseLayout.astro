---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../data/site.js";

const {
  title,
  description,
  // Path with leading and trailing slash, e.g. "/services/ai-engineering/".
  path,
  ogImage = "/og-image.jpg",
  ogImageAlt = "Greenoh — enterprise AI engineering, software modernization, and workflow automation",
  // Page-specific JSON-LD nodes appended to the shared @graph.
  schema = [],
  noindex = false,
} = Astro.props;

const canonical = new URL(path, SITE.url).href;
const ogImageUrl = new URL(ogImage, SITE.url).href;

// Shared across every page so the entity graph is consistent site-wide.
const organization = {
  "@type": "Organization",
  "@id": `${SITE.url}/#organization`,
  name: SITE.name,
  url: `${SITE.url}/`,
  logo: `${SITE.url}/logo.svg`,
  image: `${SITE.url}/og-image.jpg`,
  description: SITE.description,
  slogan: SITE.slogan,
  sameAs: [SITE.linkedin],
  areaServed: SITE.countries.map((name) => ({ "@type": "Country", name })),
  knowsAbout: [
    "Enterprise AI Engineering",
    "AI Modernization",
    "Enterprise Software Development",
    "AI Agents",
    "Workflow Automation",
    "Business Process Automation",
    "Legacy System Modernization",
    "Custom SaaS Development",
    "API Integration",
  ],
  owns: [{ "@id": `${SITE.url}/#regrely` }, { "@id": `${SITE.url}/#greenoh` }],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    email: SITE.email,
    url: `${SITE.url}/contact/`,
    areaServed: ["US", "CA", "GB", "AU", "AE"],
    availableLanguage: ["English"],
  },
};

const website = {
  "@type": "WebSite",
  "@id": `${SITE.url}/#website`,
  url: `${SITE.url}/`,
  name: SITE.name,
  description: SITE.description,
  publisher: { "@id": `${SITE.url}/#organization` },
  inLanguage: "en",
};

const webPage = {
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: title,
  description,
  isPartOf: { "@id": `${SITE.url}/#website` },
  about: { "@id": `${SITE.url}/#organization` },
  primaryImageOfPage: { "@id": `${canonical}#primaryimage` },
  inLanguage: "en",
};

const primaryImage = {
  "@type": "ImageObject",
  "@id": `${canonical}#primaryimage`,
  url: ogImageUrl,
  contentUrl: ogImageUrl,
  width: 1200,
  height: 630,
  caption: ogImageAlt,
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [organization, website, webPage, primaryImage, ...schema],
};

const ASSET_VERSION = "20260714-8";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={
        noindex
          ? "noindex, follow"
          : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
      }
    />
    <meta name="theme-color" content="#070a12" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2032%2032'%3E%3Cdefs%3E%3ClinearGradient%20id='g'%20x1='0'%20y1='0'%20x2='1'%20y2='1'%3E%3Cstop%20offset='0%25'%20stop-color='%2354d7ff'/%3E%3Cstop%20offset='55%25'%20stop-color='%2376f0b1'/%3E%3Cstop%20offset='100%25'%20stop-color='%23ffd166'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect%20width='32'%20height='32'%20rx='8'%20fill='%230b1020'/%3E%3Cpath%20d='M26.4%2010A12%2012%200%201%200%2026.4%2022'%20fill='none'%20stroke='url(%23g)'%20stroke-width='2.2'%20stroke-linecap='round'/%3E%3Cpath%20d='M8%2021C13%2021%2013%2011%2018%2011C23%2011%2022%2016%2028%2016'%20fill='none'%20stroke='url(%23g)'%20stroke-width='2.4'%20stroke-linecap='round'/%3E%3Ccircle%20cx='8'%20cy='21'%20r='2.1'%20fill='%2354d7ff'/%3E%3Ccircle%20cx='18'%20cy='11'%20r='1.9'%20fill='%2376f0b1'/%3E%3Ccircle%20cx='28'%20cy='16'%20r='2.1'%20fill='%23ffd166'/%3E%3C/svg%3E"
    />

    <script type="application/ld+json" set:html={JSON.stringify(graph)} />

    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5NH4K19BH1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-5NH4K19BH1");
    </script>

    <link rel="stylesheet" href={`/styles.css?v=${ASSET_VERSION}`} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline src={`/script.js?v=${ASSET_VERSION}`}></script>
  </body>
</html>
