---
// gradientId must be unique per instance — duplicate SVG defs IDs in one
// document make every reference resolve to the first one.
const { gradientId = "brandLogoGradient" } = Astro.props;
---

<span class="brand-mark" aria-hidden="true">
  <svg class="brand-logo" viewBox="0 0 32 32" role="img" aria-hidden="true">
    <defs>
      <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#54d7ff" />
        <stop offset="55%" stop-color="#76f0b1" />
        <stop offset="100%" stop-color="#ffd166" />
      </linearGradient>
    </defs>
    <path
      class="brand-logo-moat"
      d="M26.4 10A12 12 0 1 0 26.4 22"
      fill="none"
      stroke={`url(#${gradientId})`}
      stroke-width="2.2"
      stroke-linecap="round"
    />
    <path
      class="brand-logo-flow"
      d="M8 21C13 21 13 11 18 11C23 11 22 16 28 16"
      fill="none"
      stroke={`url(#${gradientId})`}
      stroke-width="2.4"
      stroke-linecap="round"
    />
    <circle cx="8" cy="21" r="2.1" fill="#54d7ff" />
    <circle cx="18" cy="11" r="1.9" fill="#76f0b1" />
    <circle cx="28" cy="16" r="2.1" fill="#ffd166" />
  </svg>
</span>
