---
import { SITE } from "../data/site.js";

// nextPath is where FormSubmit sends the user back after delivery. script.js
// reads ?submitted=1 there to show the success state and fire generate_lead.
const { nextPath = "/?submitted=1#contact" } = Astro.props;
const next = new URL(nextPath, SITE.url).href;
---

<form
  class="contact-form reveal"
  id="contactForm"
  action={`https://formsubmit.co/${SITE.email}`}
  method="POST"
  novalidate
>
  <input type="hidden" name="_subject" value="New project brief — Flowmoat website" />
  <input type="hidden" name="_next" value={next} />
  <input type="hidden" name="_template" value="table" />
  <input class="bot-field" type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <div class="form-row">
    <label for="name">Name</label>
    <input id="name" name="name" type="text" autocomplete="name" required />
    <small class="error-message"></small>
  </div>
  <div class="form-row">
    <label for="email">Work email</label>
    <input id="email" name="email" type="email" autocomplete="email" required />
    <small class="error-message"></small>
  </div>
  <div class="form-row">
    <label for="company">Company</label>
    <input id="company" name="company" type="text" autocomplete="organization" required />
    <small class="error-message"></small>
  </div>
  <div class="form-row">
    <label for="budget">Budget range</label>
    <select id="budget" name="budget" required>
      <option value="">Select a range</option>
      <option value="10k-25k">$10,000 - $25,000</option>
      <option value="25k-50k">$25,000 - $50,000</option>
      <option value="50k-100k">$50,000 - $100,000</option>
      <option value="100k-plus">$100,000+</option>
      <option value="not-sure">Not sure yet</option>
    </select>
    <small class="error-message"></small>
  </div>
  <div class="form-row full">
    <label for="automation">What do you want to build, modernize, or make AI-powered?</label>
    <textarea id="automation" name="automation" rows="5" required minlength="20"></textarea>
    <small class="error-message"></small>
  </div>
  <div class="captcha-notice" role="note" aria-label="Spam protection enabled">
    <span class="captcha-shield" aria-hidden="true">✓</span>
    <span>
      <strong>Protected by reCAPTCHA</strong>
      <small>You will complete an “I’m not a robot” check before your brief is delivered.</small>
    </span>
  </div>
  <button class="btn btn-primary form-submit" type="submit">Discuss My Project</button>
  <p class="form-success" role="status" aria-live="polite"></p>
</form>
