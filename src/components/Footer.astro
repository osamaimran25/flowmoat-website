---
import BrandMark from "./BrandMark.astro";
import { SITE } from "../data/site.js";
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <a class="brand" href="/">
        <BrandMark gradientId="brandLogoGradientFooter" />
        <span data-brand>Flowmoat</span>
      </a>
      <p>
        Flowmoat is an enterprise AI engineering company helping growing organizations modernize
        operations through intelligent software and automation.
      </p>
      <a
        class="footer-social"
        href={SITE.linkedin}
        target="_blank"
        rel="noopener"
        aria-label="Flowmoat on LinkedIn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
          />
        </svg>
        <span>LinkedIn</span>
      </a>
    </div>
    <div class="footer-links" aria-label="Footer navigation">
      <a href="/services/">Services</a>
      <a href="/work/">Work</a>
      <a href="/blog/">Insights</a>
      <a href="/about/">About</a>
      <a href="/contact/">Discuss Your AI Roadmap</a>
    </div>
  </div>
</footer>
