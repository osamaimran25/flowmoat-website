---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Faq from "../../components/Faq.astro";
import { SERVICES } from "../../data/services.js";
import { faqSchema, serviceSchema, breadcrumbSchema } from "../../lib/schema.js";

const path = "/services/";
const title = "AI Engineering & Software Development Services | Flowmoat";
const description =
  "Flowmoat's four services: AI engineering, AI modernization, enterprise software development, and workflow automation — for companies in the US, UK, Canada, Australia, and the UAE.";

const definition =
  "Flowmoat offers four services: AI engineering (production AI agents, copilots, and retrieval systems), AI modernization (adding AI to existing platforms without a rebuild), enterprise software development (custom SaaS, portals, and internal systems), and workflow automation (process automation and API integration).";

const faqs = [
  {
    q: "Which Flowmoat service do we need?",
    a: "If you want AI capability you do not have today, start with AI engineering. If you want AI inside a system you already run, start with AI modernization. If a process runs on manual handoffs, start with workflow automation. If you need a platform that does not exist yet, start with enterprise software development.",
  },
  {
    q: "Can we combine more than one service?",
    a: "Most engagements do. A workflow automation project often surfaces the need for a custom platform, and an enterprise software build usually includes AI capability from the start. We scope them as one engagement rather than separate contracts.",
  },
  {
    q: "What size of company does Flowmoat work with?",
    a: "Organizations of roughly 50 to 1,000 employees with real operational or software complexity. Typical engagements range from $10,000 to $100,000+.",
  },
  {
    q: "Which countries does Flowmoat serve?",
    a: "We work with companies in the United States, Canada, the United Kingdom, Australia, and the United Arab Emirates, delivering remotely with overlap on your working hours.",
  },
];

const schema = [
  ...SERVICES.map(serviceSchema),
  faqSchema(faqs, path),
  breadcrumbSchema(
    [
      { name: "Home", path: "/" },
      { name: "Services", path },
    ],
    path,
  ),
  {
    "@type": "ItemList",
    "@id": `https://flowmoat.com${path}#services`,
    itemListElement: SERVICES.map((service, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: service.name,
      url: `https://flowmoat.com/services/${service.slug}/`,
    })),
  },
];
---

<BaseLayout {title} {description} {schema} {path}>
  <section class="section page-hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container narrow">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Services</span>
      </nav>

      <p class="eyebrow">Services</p>
      <h1>Four capabilities. One accountable engineering partner.</h1>
      <p class="hero-subheadline">
        From introducing AI to building a new operational platform, we combine product thinking and
        enterprise engineering in one focused engagement.
      </p>

      <p class="hero-definition">{definition}</p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/contact/">Book a Strategy Call</a>
        <a class="btn btn-secondary" href="/work/">See our work</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-grid">
        {
          SERVICES.map((service) => (
            <article class="service-card reveal">
              <div class="service-icon">{service.icon}</div>
              <h3>
                <a href={`/services/${service.slug}/`}>{service.name}</a>
              </h3>
              <p>{service.cardSummary}</p>
              <a class="service-link" href={`/services/${service.slug}/`}>
                Explore {service.name} <span aria-hidden="true">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="section-heading centered reveal">
        <p class="eyebrow">How to choose</p>
        <h2>Start from the outcome, not the technology.</h2>
      </div>
      <div class="why-list">
        {
          SERVICES.map((service) => (
            <div class="reveal">
              <h3>
                <a href={`/services/${service.slug}/`}>{service.name}</a>
              </h3>
              <p>{service.definition}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section faq" id="faq">
    <div class="container narrow">
      <div class="section-heading centered reveal">
        <p class="eyebrow">FAQ</p>
        <h2>Questions enterprise teams ask before starting.</h2>
      </div>
      <Faq {faqs} />
    </div>
  </section>

  <section class="section final-cta">
    <div class="container cta-panel reveal">
      <p class="eyebrow">Start with the right roadmap</p>
      <h2>Not sure which one you need? That is what the first call is for.</h2>
      <a class="btn btn-primary" href="/contact/">Book a Strategy Call</a>
    </div>
  </section>
</BaseLayout>
