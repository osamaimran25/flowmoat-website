---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq from "../components/Faq.astro";
import ContactForm from "../components/ContactForm.astro";
import { SERVICES } from "../data/services.js";
import { faqSchema, serviceSchema, PRODUCTS } from "../lib/schema.js";

const title = "Enterprise AI Engineering Company | Greenoh";
const description =
  "Greenoh is an enterprise AI engineering company. We build AI-powered software, modernize legacy systems, and automate workflows for companies in the US, UK, Canada, Australia, and the UAE. Book a strategy call.";

const faqs = [
  {
    q: "What does Greenoh build?",
    a: "We build AI-powered enterprise software, modernize existing systems, develop custom SaaS and internal platforms, and automate operational workflows.",
  },
  {
    q: "Can you add AI to our existing software?",
    a: "Yes. We can introduce AI into CRMs, ERPs, portals, SaaS products, mobile applications, and legacy systems while working within existing data, security, and operational constraints.",
  },
  {
    q: "Do you work on new products or existing systems?",
    a: "Both. We take new software from strategy to production and help established organizations modernize systems already central to their operations.",
  },
  {
    q: "How do engagements begin?",
    a: "Most engagements begin with strategy and discovery. We clarify the business outcome, map the current environment, identify the highest-value opportunities, and define a phased delivery roadmap.",
  },
  {
    q: "Can Greenoh support the software after launch?",
    a: "Yes. We can provide ongoing engineering, optimization, monitoring, and product evolution after the initial release.",
  },
  {
    q: "Who does Greenoh work with?",
    a: "We work best with founders, CEOs, CTOs, COOs, product leaders, and operations leaders at growing companies with meaningful software or workflow complexity.",
  },
];

const schema = [
  ...SERVICES.map(serviceSchema),
  ...PRODUCTS,
  faqSchema(faqs, "/"),
];
---

<BaseLayout {title} {description} {schema} path="/" ogImage="/og/home.jpg" ogImageAlt="Greenoh — enterprise AI engineering that modernizes how your business runs">
  <section class="hero section" id="home">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <p class="eyebrow">Enterprise AI engineering company</p>
        <h1>Enterprise AI engineering that modernizes how your business runs.</h1>
        <p class="hero-subheadline">
          Greenoh helps growing companies reduce manual work, modernize critical systems,
          and launch intelligent products through AI engineering, enterprise software, and
          workflow automation.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary js-contact-cta" href="#contact">Book a Strategy Call</a>
          <a class="btn btn-secondary" href="#use-cases">Explore Our Work</a>
        </div>
        <p class="hero-definition">
          Greenoh is an enterprise AI engineering company serving organizations of 50–1,000 employees
          across the United States, Canada, the United Kingdom, Australia, and the UAE. We build
          AI-powered software, modernize legacy systems, and automate workflows — and we build our own
          products, RegRely and GreenOH.pk.
        </p>
      </div>

      <div class="hero-visual reveal" aria-label="Live enterprise AI operating system canvas">
        <div class="workflow-canvas" data-workflow-canvas>
          <div class="os-readout os-readout-left" aria-hidden="true">
            <span>ORCHESTRATION</span>
            <strong>Live Control Plane</strong>
          </div>
          <div class="os-readout os-readout-right" aria-hidden="true">
            <span>MODEL ROUTER</span>
            <strong>Policy-aware agents</strong>
          </div>
          <div class="canvas-toolbar">
            <div>
              <span class="status-dot"></span>
              <span>Enterprise AI system running</span>
            </div>
            <div class="run-pill">Production-ready architecture</div>
          </div>

          <div class="automation-stage">
            <svg class="workflow-lines" viewBox="0 0 760 560" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#54d7ff" />
                  <stop offset="52%" stop-color="#76f0b1" />
                  <stop offset="100%" stop-color="#ffd166" />
                </linearGradient>
                <filter id="lineGlow">
                  <feGaussianBlur stdDeviation="4" result="blur" />
                  <feMerge>
                    <feMergeNode in="blur" />
                    <feMergeNode in="SourceGraphic" />
                  </feMerge>
                </filter>
              </defs>
              <path id="pathLeadAi" class="workflow-path" d="M152 112 C266 112 266 258 380 258" />
              <path id="pathAiCrm" class="workflow-path" d="M380 258 C494 258 494 112 608 112" />
              <path id="pathAiSlack" class="workflow-path" d="M380 258 C380 350 152 345 152 437" />
              <path id="pathSlackEmail" class="workflow-path" d="M152 437 C266 437 281 459 395 459" />
              <path id="pathEmailCalendar" class="workflow-path" d="M395 459 C509 459 547 410 623 381" />
              <path id="pathCrmCalendar" class="workflow-path" d="M608 112 C668 190 668 300 623 381" />

              <circle class="data-packet packet-one" r="5">
                <animateMotion dur="3.8s" repeatCount="indefinite" rotate="auto">
                  <mpath href="#pathLeadAi" />
                </animateMotion>
              </circle>
              <circle class="data-packet packet-two" r="5">
                <animateMotion dur="4.4s" begin=".7s" repeatCount="indefinite" rotate="auto">
                  <mpath href="#pathAiCrm" />
                </animateMotion>
              </circle>
              <circle class="data-packet packet-three" r="5">
                <animateMotion dur="4.9s" begin="1.1s" repeatCount="indefinite" rotate="auto">
                  <mpath href="#pathSlackEmail" />
                </animateMotion>
              </circle>
              <circle class="data-packet packet-four" r="5">
                <animateMotion dur="5.2s" begin="1.8s" repeatCount="indefinite" rotate="auto">
                  <mpath href="#pathEmailCalendar" />
                </animateMotion>
              </circle>
            </svg>

            <div class="workflow-node node-lead" data-node="lead">
              <span class="node-icon">LF</span>
              <strong>Business System</strong>
              <small>CRM, ERP, SaaS, portal</small>
            </div>
            <div class="workflow-node node-ai is-thinking" data-node="ai">
              <span class="node-icon">AI</span>
              <strong>Agent Mesh</strong>
              <small data-ai-status>Reading context...</small>
              <span class="thinking-dots"><i></i><i></i><i></i></span>
            </div>
            <div class="workflow-node node-crm" data-node="crm">
              <span class="node-icon">CRM</span>
              <strong>Data Layer</strong>
              <small>Synced and enriched</small>
            </div>
            <div class="workflow-node node-slack" data-node="slack">
              <span class="node-icon">SL</span>
              <strong>Web App</strong>
              <small>AI-powered interface</small>
            </div>
            <div class="workflow-node node-email" data-node="email">
              <span class="node-icon">EM</span>
              <strong>Cloud API</strong>
              <small>Secure orchestration</small>
            </div>
            <div class="workflow-node node-calendar" data-node="calendar">
              <span class="node-icon">CAL</span>
              <strong>Decision Loop</strong>
              <small>Actions and insights</small>
            </div>
          </div>

          <div class="canvas-footer">
            <div class="live-metrics">
              <div>
                <strong>Human</strong>
                <span>approval controls</span>
              </div>
              <div>
                <strong>Secure</strong>
                <span>system integration</span>
              </div>
              <div>
                <strong>Scalable</strong>
                <span>enterprise architecture</span>
              </div>
            </div>
            <div class="live-log" aria-live="polite">
              <div class="log-title">Live event stream</div>
              <ul data-live-log>
                <li><span>12:04:08</span> Agent retrieved enterprise context</li>
                <li><span>12:04:11</span> API workflow executed successfully</li>
                <li><span>12:04:17</span> AI insight delivered to dashboard</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section problem" id="problem">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Built around business impact</p>
        <h2>Move from operational friction to scalable execution.</h2>
        <p>Technology should remove constraints from your business. Every engagement starts with the operational outcome, then works backward to the right architecture.</p>
      </div>
      <div class="three-grid">
        <article class="glass-card reveal">
          <span class="card-number">01</span>
          <h3>Reduce manual work</h3>
          <p>Automate repetitive processes, handoffs, and data movement so your team can focus on higher-value decisions.</p>
        </article>
        <article class="glass-card reveal">
          <span class="card-number">02</span>
          <h3>Modernize critical software</h3>
          <p>Extend or replace aging systems without disrupting the operations, data, and users that already depend on them.</p>
        </article>
        <article class="glass-card reveal">
          <span class="card-number">03</span>
          <h3>Launch and scale faster</h3>
          <p>Move from roadmap to production-ready software with an accountable engineering partner built for long-term delivery.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section solution" id="solution">
    <div class="container split-layout">
      <div class="section-heading reveal">
        <p class="eyebrow">Serious engineering for real operations</p>
        <h2>Turn disconnected tools and aging software into intelligent business systems.</h2>
        <p>
          We partner with founders, technology leaders, and operations teams to make complex
          workflows easier to run, govern, and scale.
        </p>
      </div>
      <div class="solution-list reveal">
        <div><span></span>Reduce delays, repetitive work, and avoidable operational cost</div>
        <div><span></span>Introduce useful AI inside the products and systems you already own</div>
        <div><span></span>Replace fragmented workflows with clear, accountable software</div>
        <div><span></span>Launch new SaaS and internal platforms with enterprise foundations</div>
        <div><span></span>Scale delivery without adding unnecessary systems or headcount</div>
      </div>
    </div>
  </section>

  <section class="section finder" id="ai-finder">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">AI opportunity finder</p>
        <h2>Identify where intelligent software could create the most value.</h2>
        <p>Describe a workflow, system, or operational constraint. We will surface practical opportunity areas to explore with your team.</p>
      </div>

      <div class="finder-card reveal">
        <div class="finder-input">
          <textarea
            id="finderInput"
            rows="3"
            maxlength="400"
            placeholder="e.g. Our operations team manually moves customer data between our CRM, ERP, and reporting tools..."
            aria-label="Describe your business or workflow"
          ></textarea>
          <div class="finder-actions">
            <div class="finder-chips" data-finder-examples>
              <button type="button" class="finder-chip">Legacy system modernization</button>
              <button type="button" class="finder-chip">Customer operations</button>
              <button type="button" class="finder-chip">Document workflows</button>
              <button type="button" class="finder-chip">Disconnected business systems</button>
            </div>
            <button type="button" class="btn btn-primary" id="finderRun">
              <span class="finder-spark" aria-hidden="true">✦</span> Map Opportunities
            </button>
          </div>
        </div>

        <div class="finder-output" data-finder-output hidden>
          <div class="finder-scan" data-finder-scan>
            <span class="finder-scan-dot"></span>
            <span data-finder-status>Analyzing your workflow...</span>
          </div>
          <div class="finder-results" data-finder-results></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="services">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">What we build</p>
        <h2>Four capabilities. One accountable engineering partner.</h2>
        <p>From introducing AI to building a new operational platform, we combine product thinking and enterprise engineering in one focused engagement.</p>
      </div>
      <div class="services-grid">
        {
          SERVICES.map((service) => (
            <article class="service-card reveal">
              <div class="service-icon">{service.icon}</div>
              <h3>
                <a href={`/services/${service.slug}/`}>{service.name}</a>
              </h3>
              <p>{service.cardSummary}</p>
              <a class="service-link" href={`/services/${service.slug}/`}>
                Explore {service.name} <span aria-hidden="true">→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="products">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">Our products</p>
        <h2>We do not only advise on software. We build and operate real SaaS products.</h2>
        <p>Our products reflect the same discipline we bring to client work: complex operations made clear, intelligent, and scalable.</p>
      </div>
      <div class="services-grid">
        <article class="service-card reveal">
          <div class="service-icon">RR</div>
          <p class="eyebrow">Compliance &amp; privacy</p>
          <h3>RegRely</h3>
          <p>AI-powered Compliance &amp; Privacy Management Platform helping organizations manage compliance, privacy operations, vendor risk, and governance.</p>
          <a class="btn btn-secondary" href="https://regrely.com" target="_blank" rel="noreferrer">Explore RegRely</a>
        </article>
        <article class="service-card reveal">
          <div class="service-icon">GOH</div>
          <p class="eyebrow">Pakistan's solar marketplace</p>
          <h3>GreenOH.pk</h3>
          <p>Compare verified solar installers, explore solar solutions, and make confident decisions through one trusted platform.</p>
          <a class="btn btn-secondary" href="https://greenoh.pk" target="_blank" rel="noreferrer">Explore GreenOH.pk</a>
        </article>
        <article class="service-card reveal">
          <div class="service-icon">OWN</div>
          <p class="eyebrow">Product experience</p>
          <h3>Built from the inside</h3>
          <p>Our product portfolio gives us firsthand experience turning complex business domains into scalable software—not just delivering isolated features.</p>
        </article>
        <article class="service-card reveal">
          <div class="service-icon">SCL</div>
          <p class="eyebrow">Enterprise foundations</p>
          <h3>Designed to evolve</h3>
          <p>We apply the same focus on adoption, maintainability, governance, and long-term ownership to every client system we engineer.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section use-cases" id="use-cases">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Selected work</p>
        <h2>Enterprise platforms and solutions built around real operational complexity.</h2>
        <p>Our work spans owned SaaS platforms and tailored business systems designed to make complex operations easier to run, govern, and scale.</p>
      </div>
      <div class="use-case-grid">
        <div class="use-case reveal"><strong>AI Compliance Platform — RegRely.</strong> A connected operating layer for compliance programs, privacy operations, vendor risk, governance, evidence, and accountability.</div>
        <div class="use-case reveal"><strong>Pakistan's Solar Marketplace &amp; Aggregation Platform — GreenOH.pk.</strong> A trusted platform for discovering, comparing, and connecting with verified solar solution providers for homes and businesses.</div>
        <div class="use-case reveal"><strong>AI Modernization for Legacy Systems.</strong> Extend established CRMs, ERPs, portals, and internal systems with intelligent search, document processing, and decision support.</div>
        <div class="use-case reveal"><strong>Custom Operations Platforms.</strong> Replace fragmented spreadsheets, manual handoffs, and disconnected tools with software designed around how the business operates.</div>
      </div>
    </div>
  </section>

  <section class="section process" id="process">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">From strategy to production</p>
        <h2>A clear path from business problem to scalable system.</h2>
      </div>
      <div class="process-track">
        <article class="process-step reveal">
          <span>01</span>
          <h3>Discover</h3>
          <p>Map the objective, current workflow, users, systems, data, constraints, and success criteria.</p>
        </article>
        <article class="process-step reveal">
          <span>02</span>
          <h3>Architect</h3>
          <p>Define the product experience, technical approach, integration boundaries, controls, and phased delivery plan.</p>
        </article>
        <article class="process-step reveal">
          <span>03</span>
          <h3>Build</h3>
          <p>Deliver working software in focused iterations, with regular demonstrations and transparent decisions.</p>
        </article>
        <article class="process-step reveal">
          <span>04</span>
          <h3>Scale</h3>
          <p>Support rollout, measure performance, strengthen the system, and evolve it as your business grows.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section results" id="results">
    <div class="container results-grid">
      <div class="section-heading reveal">
        <p class="eyebrow">Engineered for real operations</p>
        <h2>Software your teams can trust, adopt, and grow with.</h2>
        <p>Enterprise readiness is designed into the architecture, delivery process, and operating model from the start.</p>
      </div>
      <div class="result-cards">
        <div class="result-card reveal">
          <strong>Secure by design</strong>
          <span>Access, data boundaries, auditability, and operational controls are considered from the beginning.</span>
        </div>
        <div class="result-card reveal">
          <strong>Built to integrate</strong>
          <span>Clear integration boundaries connect the systems already central to your business.</span>
        </div>
        <div class="result-card reveal">
          <strong>Human controlled</strong>
          <span>Approvals, review steps, traceability, and fallback paths support critical decisions.</span>
        </div>
        <div class="result-card reveal">
          <strong>Made to evolve</strong>
          <span>Maintainable architecture supports long-term ownership, handover, and continued growth.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section why-us" id="why-us">
    <div class="container split-layout">
      <div class="section-heading reveal">
        <p class="eyebrow">Why Greenoh</p>
        <h2>Built for companies that need more than code delivery.</h2>
      </div>
      <div class="why-list reveal">
        <div>
          <h3>Business-first approach</h3>
          <p>We begin with the operational or commercial outcome. Technology decisions follow the needs of the business, its users, and its constraints.</p>
        </div>
        <div>
          <h3>Product mindset</h3>
          <p>We think beyond feature lists—considering adoption, maintainability, workflows, ownership, and how software creates value over time.</p>
        </div>
        <div>
          <h3>Enterprise architecture</h3>
          <p>We design for security, integration, performance, governance, and change so the system can grow with the organization.</p>
        </div>
        <div>
          <h3>Long-term partnership</h3>
          <p>We stay accountable beyond the first release, helping teams improve, extend, and operate software as requirements evolve.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="ideal-client">
    <div class="container">
      <div class="section-heading centered reveal">
        <p class="eyebrow">Who we partner with</p>
        <h2>Built for growing companies with meaningful operational complexity.</h2>
        <p>Greenoh works best with organizations of approximately 50–1,000 employees and a clear owner for the business outcome across North America, the United Kingdom, and Australia.</p>
      </div>
      <div class="three-grid">
        <article class="glass-card reveal">
          <span class="card-number">LEADERSHIP</span>
          <h3>Founders, CEOs, and CTOs</h3>
          <p>Launch or modernize digital products, strengthen architecture, and turn strategic AI initiatives into production systems.</p>
        </article>
        <article class="glass-card reveal">
          <span class="card-number">OPERATIONS</span>
          <h3>COOs and VP Operations</h3>
          <p>Reduce manual work, connect fragmented systems, and give teams better visibility and control across critical workflows.</p>
        </article>
        <article class="glass-card reveal">
          <span class="card-number">PRODUCT</span>
          <h3>Product and technology teams</h3>
          <p>Introduce practical AI into existing customer experiences or build a new SaaS or internal platform with an accountable partner.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section faq" id="faq">
    <div class="container narrow">
      <div class="section-heading centered reveal">
        <p class="eyebrow">FAQ</p>
        <h2>Questions enterprise teams ask before starting.</h2>
      </div>
      <Faq faqs={faqs} />
    </div>
  </section>

  <section class="section final-cta">
    <div class="container cta-panel reveal">
      <p class="eyebrow">Start with the right roadmap</p>
      <h2>Turn your AI or software initiative into a system your business can rely on.</h2>
      <a class="btn btn-primary js-contact-cta" href="#contact">Book a Strategy Call</a>
    </div>
  </section>

  <section class="section contact" id="contact">
    <div class="container contact-grid">
      <div class="section-heading reveal">
        <p class="eyebrow">Contact</p>
        <h2>Tell us what you want to improve, build, or modernize.</h2>
        <p>
          Share the business goal and current context. An AI engineering expert will review your request and respond with the most relevant next step.
        </p>
      </div>

      <ContactForm nextPath="/?submitted=1#contact" />
    </div>
  </section>
</BaseLayout>
